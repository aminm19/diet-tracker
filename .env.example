# --- Server-only: never expose these to the client bundle ---

# Neon Postgres connection string (pooled endpoint). Set by `neon link` in Unit 2.
DATABASE_URL=

# USDA FoodData Central API key. Free signup: https://api.data.gov/signup/
USDA_FDC_API_KEY=

# Port the Hono server listens on.
PORT=3000

# --- Client-side (safe to expose, prefixed with VITE_) ---

# Base URL the client uses to reach the API.
VITE_API_URL=http://localhost:3000
